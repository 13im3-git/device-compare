<section class="category-page">
  <div class="container">
    <div class="category-header">
      <h1 class="page-title"><%= category %></h1>
      <p class="category-subtitle">Browse all <%= category.toLowerCase() %> devices</p>
    </div>

    <div class="devices-grid">
      <% devices.forEach(device => { %>
        <%- include('partials/device-card', { device }) %>
      <% }) %>
    </div>

    <% if(devices.length === 0) { %>
      <div class="no-results">
        <h3>No devices in this category yet</h3>
        <p>Check back soon for new additions.</p>
      </div>
    <% } %>
  </div>
</section>