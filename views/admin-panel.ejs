<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - DeviceCompare</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    .admin-page { padding: 2rem 0; background: #0f0f1a; min-height: 100vh; color: #e0e0e0; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid #16213e; }
    .admin-header h1 { color: #fff; }
    .admin-nav { display: flex; gap: 1rem; }
    .btn-add { background: #4f46e5; color: white; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-weight: 500; }
    .btn-add:hover { background: #4338ca; }
    .btn-logout { background: #7f1d1d; color: #fca5a5; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-weight: 500; border: none; cursor: pointer; }
    .btn-logout:hover { background: #991b1b; }
    .devices-table { width: 100%; background: #1a1a2e; border-radius: 12px; overflow: hidden; border: 1px solid #16213e; }
    .devices-table th { background: #16213e; padding: 1rem; text-align: left; color: #fff; font-weight: 600; }
    .devices-table td { padding: 1rem; border-top: 1px solid #16213e; }
    .devices-table tr:hover td { background: #1f2937; }
    .badge { display: inline-block; padding: 0.25rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: #4f46e5; color: white; }
    .actions-cell { display: flex; gap: 0.5rem; }
    .btn-sm { padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.85rem; text-decoration: none; font-weight: 500; }
    .btn-edit { background: #4f46e5; color: white; }
    .btn-delete { background: #7f1d1d; color: #fca5a5; border: none; cursor: pointer; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: #1a1a2e; padding: 1.5rem; border-radius: 12px; border: 1px solid #16213e; }
    .stat-value { font-size: 1.8rem; font-weight: 700; color: #fff; }
    .stat-label { color: #888; font-size: 0.85rem; margin-top: 0.25rem; }
  </style>
</head>
<body>
  <div class="admin-page">
    <div class="container">
      <div class="admin-header">
        <div>
          <h1>Admin Dashboard</h1>
          <p style="color: #888; margin-top: 0.25rem;">Welcome, <%= user.email %></p>
        </div>
        <div class="admin-nav">
          <a href="/sys-panel-8x3k1/add" class="btn-add">+ Add Device</a>
          <form method="POST" action="/sys-panel-8x3k1/logout" style="display: inline;">
            <button type="submit" class="btn-logout">Logout</button>
          </form>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-value"><%= devices.length %></div>
          <div class="stat-label">Total Devices</div>
        </div>
        <div class="stat-card">
          <div class="stat-value"><%= categories.length %></div>
          <div class="stat-label">Categories</div>
        </div>
        <div class="stat-card">
          <div class="stat-value"><%= devices.filter(function(d){ return d.rating >= 4.5; }).length %></div>
          <div class="stat-label">Highly Rated</div>
        </div>
      </div>

      <h2 style="margin-bottom: 1rem; color: #fff;">All Devices</h2>
      <table class="devices-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Brand</th>
            <th>Category</th>
            <th>Price</th>
            <th>Rating</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% devices.forEach(function(device){ %>
            <tr>
              <td><%= device.id %></td>
              <td><strong><%= device.name %></strong></td>
              <td><%= device.brand %></td>
              <td><span class="badge"><%= device.category %></span></td>
              <td>$<%= device.price.toLocaleString() %></td>
              <td><%= device.rating.toFixed(1) %> ★</td>
              <td><%= device.availability ? '<span style="color: #4ade80;">Active</span>' : '<span style="color: #f87171;">Hidden</span>' %></td>
              <td class="actions-cell">
                <a href="/sys-panel-8x3k1/edit/<%= device.id %>" class="btn-sm btn-edit">Edit</a>
                <form method="POST" action="/sys-panel-8x3k1/delete/<%= device.id %>" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                  <button type="submit" class="btn-sm btn-delete">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <% if(devices.length === 0) { %>
        <div style="text-align: center; padding: 3rem; color: #888;">
          <h3>No devices yet</h3>
          <p>Start by adding your first device.</p>
          <a href="/sys-panel-8x3k1/add" class="btn-add" style="display: inline-block; margin-top: 1rem;">+ Add Device</a>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>